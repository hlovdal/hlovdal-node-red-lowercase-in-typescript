{
  "name": "@hlovdal/node-red-lowercase-in-typescript-cjs",
  "type": "commonjs",
  "version": "1.0.0",
  "description": "The standard Creating your first node lowercase example, but converted to Typescript",
  "main": "dist/src/lower-case.js",
  "files": [
    "LICENCE",
    "README.md",
    "dist/src/file.svg",
    "dist/src/lower-case.html",
    "dist/src/lower-case.js",
    "package.json"
  ],
  "scripts": {
    "precy:open": "npm run pree2e",
    "cy:open": "cypress open",
    "postcy:open": "npm run poste2e",
    "cy:run": "env TERM=${TERM:-vt100} cypress run",
    "pree2e": "npm run build && bash bin/upload_file_path_update.sh",
    "e2e": "bash bin/run-e2e.sh",
    "poste2e": "bash bin/upload_file_path_clean.sh",
    "lint": "eslint src",
    "compile": "rimraf dist && tsc",
    "build": "npm run compile && cpy --flat src/*.html src/*.svg dist/src && npm pack",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --reporter=default --no-file-parallelism"
  },
  "keywords": [
    "lower-case",
    "lowercase",
    "node-red",
    "typescript"
  ],
  "author": {
    "name": "Håkon Løvdal",
    "email": "kode@denkule.no"
  },
  "homepage": "https://github.com/hlovdal/hlovdal-node-red-lowercase-in-typescript#readme",
  "bugs": "https://github.com/hlovdal/hlovdal-node-red-lowercase-in-typescript/issues",
  "node-red": {
    "version": ">=3.1.0",
    "nodes": {
      "lower-case": "dist/src/lower-case.js"
    }
  },
  "license": "Apache-2.0",
  "overrides": {
    "sinon": {
      "diff": "^8.0.3"
    }
  },
  "dependencies": {
    "node-red": "^5.0.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/node-red": "^1.3.5",
    "@types/node-red-node-test-helper": "^0.3.5",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "cpy-cli": "^7.0.0",
    "cypress": "^15.18.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "node-red-node-test-helper": "^0.3.6",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "node": ">= 20"
  }
}
